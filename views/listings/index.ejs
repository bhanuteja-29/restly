<% layout('/layouts/boilerplate.ejs') -%>
	<div class="container py-3  d-none d-md-block">
		<div class="d-flex flex-wrap justify-content-between text-center filters ">

			<a href="/listings/filter/?category=Hotels"
				class="filter p-2 <%= selectedCategory === 'Hotels' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div><i class="fa-solid fa-bed"></i></div>
					<p>Hotels</p>
				</div>
			</a>

			<a href="/listings/filter/?category=Iconic Cities"
				class="filter p-2 <%= selectedCategory === 'Iconic Cities' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div><i class="fa-solid fa-city"></i></div>
					<p>Iconic Cities</p>
				</div>
			</a>

			<a href="/listings/filter/?category=Mountains"
				class="filter p-2 <%= selectedCategory === 'Mountains' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div><i class="fa-solid fa-mountain-sun"></i></div>
					<p>Mountains</p>
				</div>
			</a>

			<a href="/listings/filter/?category=Castles"
				class="filter p-2 <%= selectedCategory === 'Castles' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div><i class="fa-brands fa-fort-awesome"></i></div>
					<p>Castles</p>
				</div>
			</a>

			<a href="/listings/filter/?category=Swimming"
				class="filter p-2 <%= selectedCategory === 'Swimming' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div>
						<i class="fa-solid fa-person-swimming"></i>
					</div>
					<p>Swimming</p>
				</div>
			</a>

			<a href="/listings/filter/?category=Farms"
				class="filter p-2 <%= selectedCategory === 'Farms' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div>
						<i class="fa-solid fa-cow"></i>
					</div>
					<p>Farms</p>
				</div>
			</a>

			<a href="/listings/filter/?category=Hill Stations"
				class="filter p-2 <%= selectedCategory === 'Hill Stations' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div>
						<i class="fa-solid fa-snowflake"></i>
					</div>
					<p>Hill Stations</p>
				</div>
			</a>

			<a href="/listings/filter/?category=Beach"
				class="filter p-2 <%= selectedCategory === 'Beach' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div>
						<i class="fa-solid fa-umbrella-beach"></i>
					</div>
					<p>Beach</p>
				</div>
			</a>

			<a href="/listings/filter/?category=Camping"
				class="filter p-2 <%= selectedCategory === 'Camping' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div>
						<i class="fa-solid fa-campground"></i>
					</div>
					<p>Camping</p>
				</div>
			</a>

			<a href="/listings/filter/?category=Historical Homes"
				class="filter p-2 <%= selectedCategory === 'Historical Homes' ? 'active-filter' : '' %>">
				<div class="filter p-2">
					<div>
						<i class="fa-solid fa-hotel"></i>
					</div>
					<p>Historical Homes</p>
				</div>
			</a>

			<div class="form-check-reverse form-switch tax-toggle">
				<input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
				<label class="form-check-label" for="switchCheckDefault">Include Taxes</label>
			</div>
		</div>
	</div>

	<!-- Mobile Filter Button -->
	<div class="container py-2 d-md-none">
		<button class="btn btn-dark w-100 rounded-pill shadow-sm" data-bs-toggle="offcanvas"
			data-bs-target="#mobileFilters">
			<i class="fa-solid fa-sliders me-2"></i>Filters
		</button>
	</div>
	<div class="container pb-4">
		<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
			<% for(let listing of listings) { %>
				<a href="/listings/<%=listing._id%>" class="listing-link">
					<div class="card col listing-card">
						<img src="<%=listing.image.url%>" class="card-img-top" alt="...">
						<div class="card-img-overlay"></div>
						<div class="card-body">
							<p class="card-text">
								<b>
									<%=listing.title%>
								</b> <br>
								&#8377;<%=listing.price.toLocaleString('en-IN')%>/night
									<i class="tax"> &nbsp;+ 18% GST</i>
							</p>
						</div>
					</div>
				</a>
				<% } %>
		</div>
	</div>

	<!-- Mobile Filters Offcanvas -->
	<div class="offcanvas offcanvas-bottom" tabindex="-1" id="mobileFilters">

		<div class="offcanvas-header">
			<h5 class="offcanvas-title">Filters</h5>
			<button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
		</div>

		<div class="offcanvas-body">

			<div class="filters-grid">

				<a href="/listings/filter/?category=Hotels"
					class="filter-item <%= selectedCategory === 'Hotels' ? 'active-filter' : '' %>">
					<i class="fa-solid fa-bed"></i>
					<span>Hotels</span>
				</a>

				<a href="/listings/filter/?category=Iconic Cities"
					class="filter-item <%= selectedCategory === 'Iconic Cities' ? 'active-filter' : '' %>">
					<i class="fa-solid fa-city"></i>
					<span>Iconic Cities</span>
				</a>

				<!-- repeat same pattern for others -->

				<a href="/listings/filter/?category=Mountains"
					class="filter-item  <%= selectedCategory === 'Mountains' ? 'active-filter' : '' %>">
						<i class="fa-solid fa-mountain-sun"></i>
						<span>Mountains</span>
				</a>

				<a href="/listings/filter/?category=Castles"
					class="filter-item<%= selectedCategory === 'Castles' ? 'active-filter' : '' %>">
						<i class="fa-brands fa-fort-awesome"></i>
						<span>Castles</span>
				</a>

				<a href="/listings/filter/?category=Swimming"
					class="filter-item<%= selectedCategory === 'Swimming' ? 'active-filter' : '' %>">
						<i class="fa-solid fa-person-swimming"></i>
						<span>Swimming</span>
				</a>

				<a href="/listings/filter/?category=Farms"
					class="filter-item<%= selectedCategory === 'Farms' ? 'active-filter' : '' %>">
						<i class="fa-solid fa-cow"></i>
						<span>Farms</span>
				</a>

				<a href="/listings/filter/?category=Hill Stations"
					class="filter-item<%= selectedCategory === 'Hill Stations' ? 'active-filter' : '' %>">
						<i class="fa-solid fa-snowflake"></i>
						<span>Hill Stations</span>
				</a>

				<a href="/listings/filter/?category=Beach"
					class="filter-item<%= selectedCategory === 'Beach' ? 'active-filter' : '' %>">
						<i class="fa-solid fa-umbrella-beach"></i>
						<span>Beach</span>
				</a>

				<a href="/listings/filter/?category=Camping"
					class="filter-item<%= selectedCategory === 'Camping' ? 'active-filter' : '' %>">
							<i class="fa-solid fa-campground"></i>
						<span>Camping</span>
				</a>

				<a href="/listings/filter/?category=Historical Homes"
					class="filter-item<%= selectedCategory === 'Historical Homes' ? 'active-filter' : '' %>">
						<i class="fa-solid fa-hotel"></i>
						<span>Historical Homes</span>
				</a>

				<!-- repeat for all categories -->

				<div class="form-check form-switch mt-3 w-100">
					<input class="form-check-input" type="checkbox" role="switch">
					<label class="form-check-label">Include Taxes</label>
				</div>

			</div>
		</div>
	</div>

	<script>
		let taxSwitch = document.querySelector('#switchCheckDefault');
		let taxes = document.querySelectorAll('.tax');

		taxSwitch.addEventListener('change', () => {
			taxes.forEach(tax => {
				if (taxSwitch.checked) {
					tax.style.display = 'inline';
				} else {
					tax.style.display = 'none';
				}
			});
		});
	</script>